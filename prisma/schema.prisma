// ============================================================================
// Manual Migration Notes
// ============================================================================
// TimescaleDB Hypertable: ai_cost_log
// Prisma cannot create TimescaleDB hypertables. Run this SQL manually after migration:
// SELECT create_hypertable('ai_cost_log', 'created_at', chunk_time_interval => INTERVAL '1 day');
//
// Schema Organization:
// - public schema: All application tables (users, organizations, messages, etc.)
// - auth schema: Supabase auth tables (not managed by Prisma)
// - extensions schema: pgcrypto, pgvector, timescaledb (not managed by Prisma)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Foundation Tables (public schema)
// ============================================================================

model User {
  id        String   @id @default(gen_random_ulid()) @map("id")
  email     String   @unique @map("email")
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("users")
  @@index([email])
  @@index([createdAt(sort: Desc)])
}

model Album {
  id          String   @id @default(gen_random_ulid()) @map("id")
  orgId       String   @map("org_id")
  name        String   @map("name")
  description String?  @map("description")
  category    String   @default("general") @map("category")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("albums")
  @@index([orgId])
  @@index([category])
}

// ============================================================================
// Core Application Tables (public schema)
// ============================================================================

model Message {
  id        String   @id @default(gen_random_ulid()) @map("id")
  orgId     String   @map("org_id")
  threadId  String   @map("thread_id")
  userId    String   @map("user_id")
  content   String   @map("content")
  category  String   @default("general") @map("category")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  thread Thread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messages")
  @@index([orgId])
  @@index([threadId])
  @@index([userId])
  @@index([updatedAt(sort: Desc)])
}

model Thread {
  id        String   @id @default(gen_random_ulid()) @map("id")
  orgId     String   @map("org_id")
  title     String   @map("title")
  category  String   @default("chat") @map("category")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("threads")
  @@index([orgId])
  @@index([category])
  @@index([updatedAt(sort: Desc)])
}

model Project {
  id          String    @id @default(gen_random_ulid()) @map("id")
  orgId       String    @map("org_id")
  name        String    @map("name")
  description String?   @map("description")
  status      String    @default("active") @map("status")
  priority    String    @default("medium") @map("priority")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  budget      Decimal?  @map("budget") @db.Decimal(12, 2)
  owner       String?   @map("owner")
  clientEmail String?   @map("client_email")
  tags        String[]  @map("tags")
  category    String    @default("general") @map("category")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@map("projects")
  @@index([orgId])
  @@index([status])
  @@index([priority])
  @@index([owner])
  @@index([updatedAt(sort: Desc)])
}

model Task {
  id            String    @id @default(gen_random_ulid()) @map("id")
  projectId     String    @map("project_id")
  parentId      String?   @map("parent_id")
  title         String    @map("title")
  status        String    @default("todo") @map("status")
  assignee      String?   @map("assignee")
  dueDate       DateTime? @map("due_date")
  estimatedTime Int?      @map("estimated_time")
  priority      String    @default("medium") @map("priority")
  order         Int       @default(0) @map("order")
  checklist     Json?     @map("checklist")
  category      String    @default("general") @map("category")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    Task?      @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Task[]     @relation("TaskHierarchy")

  @@map("tasks")
  @@index([projectId])
  @@index([parentId])
  @@index([status])
  @@index([assignee])
  @@index([dueDate])
  @@index([priority])
  @@index([order])
  @@index([updatedAt(sort: Desc)])
}

model Event {
  id            String    @id @default(gen_random_ulid()) @map("id")
  orgId         String    @map("org_id")
  title         String    @map("title")
  startTime     DateTime  @map("start_time")
  endTime       DateTime  @map("end_time")
  timezone      String    @default("UTC") @map("timezone")
  allDayFlag    Boolean   @default(false) @map("all_day_flag")
  recurrenceId  String?   @map("recurrence_id")
  category      String    @default("general") @map("category")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  org           Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  recurrenceRule RecurrenceRule? @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)

  @@map("events")
  @@index([orgId])
  @@index([startTime])
  @@index([endTime])
  @@index([recurrenceId])
  @@index([category])
  @@index([updatedAt(sort: Desc)])
}

// ============================================================================
// Communication & Content Tables (public schema)
// ============================================================================

model Email {
  id            String    @id @default(gen_random_ulid()) @map("id")
  orgId         String    @map("org_id")
  accountId     String    @map("account_id")
  nylasId       String    @map("nylas_id")
  subject       String    @map("subject")
  fromAddress   String    @map("from_address")
  toAddresses   String[]  @map("to_addresses")
  ccAddresses   String[]  @map("cc_addresses")
  bccAddresses  String[]  @map("bcc_addresses")
  body          String?   @map("body")
  attachments   Json?     @map("attachments")
  direction     String    @default("inbound") @map("direction")
  category      String    @default("general") @map("category")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  org             Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("emails")
  @@index([orgId])
  @@index([accountId])
  @@index([nylasId])
  @@index([fromAddress])
  @@index([direction])
  @@index([updatedAt(sort: Desc)])
}

model Contact {
  id              String    @id @default(gen_random_ulid()) @map("id")
  orgId           String    @map("org_id")
  name            String    @map("name")
  email           String?   @map("email")
  phone           String?   @map("phone")
  company         String?   @map("company")
  privacySettings Json?     @map("privacy_settings")
  tags            String[]  @map("tags")
  additionalData  Json?     @map("additional_data")
  category        String    @default("general") @map("category")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@map("contacts")
  @@index([orgId])
  @@index([email])
  @@index([name])
  @@index([company])
  @@index([tags], type: Gin)
  @@index([updatedAt(sort: Desc)])
}

model Document {
  id          String   @id @default(gen_random_ulid()) @map("id")
  orgId       String   @map("org_id")
  name        String   @map("name")
  type        String   @map("type")
  size        BigInt   @map("size")
  storagePath String   @map("storage_path")
  isTrashed   Boolean  @default(false) @map("is_trashed")
  category    String   @default("general") @map("category")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("documents")
  @@index([orgId])
  @@index([type])
  @@index([isTrashed])
  @@index([category])
  @@index([updatedAt(sort: Desc)])
}

model Media {
  id        String   @id @default(gen_random_ulid()) @map("id")
  orgId     String   @map("org_id")
  name      String   @map("name")
  type      String   @map("type")
  url       String   @map("url")
  altText   String?  @map("alt_text")
  blurhash  String?  @map("blurhash")
  albumId   String?  @map("album_id")
  category  String   @default("general") @map("category")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  album Album?       @relation(fields: [albumId], references: [id], onDelete: SetNull)

  @@map("media")
  @@index([orgId])
  @@index([type])
  @@index([albumId])
  @@index([category])
  @@index([updatedAt(sort: Desc)])
}

// ============================================================================
// Financial & Planning Tables (public schema)
// ============================================================================

model Transaction {
  id          String    @id @default(gen_random_ulid()) @map("id")
  orgId       String    @map("org_id")
  amount      Decimal   @map("amount") @db.Decimal(12, 2)
  date        DateTime  @map("date")
  description String    @map("description")
  category    String    @default("general") @map("category")
  type        String    @default("expense") @map("type")
  isPlanned   Boolean   @default(false) @map("is_planned")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("transactions")
  @@index([orgId])
  @@index([date(sort: Desc)])
  @@index([category])
  @@index([type])
  @@index([isPlanned])
}

model Goal {
  id           String    @id @default(gen_random_ulid()) @map("id")
  orgId        String    @map("org_id")
  name         String    @map("name")
  targetValue  Decimal   @map("target_value") @db.Decimal(12, 2)
  currentValue Decimal   @default(0) @map("current_value") @db.Decimal(12, 2)
  deadline     DateTime? @map("deadline")
  category     String    @default("general") @map("category")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("goals")
  @@index([orgId])
  @@index([deadline])
  @@index([category])
  @@index([updatedAt(sort: Desc)])
}

// ============================================================================
// Research & Learning Tables (public schema)
// ============================================================================

model ResearchNotebook {
  id        String   @id @default(gen_random_ulid()) @map("id")
  orgId     String   @map("org_id")
  title     String   @map("title")
  content   String?  @map("content")
  category  String   @default("general") @map("category")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("research_notebooks")
  @@index([orgId])
  @@index([category])
  @@index([updatedAt(sort: Desc)])
}

model Flashcard {
  id           String   @id @default(gen_random_ulid()) @map("id")
  orgId        String   @map("org_id")
  frontContent String   @map("front_content")
  backContent  String   @map("back_content")
  deckName     String   @map("deck_name")
  fsrsState    Json?    @map("fsrs_state")
  category     String   @default("general") @map("category")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("flashcards")
  @@index([orgId])
  @@index([deckName])
  @@index([category])
  @@index([updatedAt(sort: Desc)])
}

// ============================================================================
// Collaboration & Communication Tables (public schema)
// ============================================================================

model ConferenceRoom {
  id             String   @id @default(gen_random_ulid()) @map("id")
  orgId          String   @map("org_id")
  name           String   @map("name")
  livekitRoomId  String   @map("livekit_room_id")
  category       String   @default("general") @map("category")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([livekitRoomId])
  @@map("conference_rooms")
  @@index([orgId])
  @@index([livekitRoomId])
  @@index([category])
}

model TranslationSession {
  id              String   @id @default(gen_random_ulid()) @map("id")
  orgId           String   @map("org_id")
  sourceLanguage  String   @map("source_language")
  targetLanguage  String   @map("target_language")
  speakers        Json?    @map("speakers")
  segments        Json?    @map("segments")
  status          String   @default("pending") @map("status")
  category        String   @default("general") @map("category")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("translation_sessions")
  @@index([orgId])
  @@index([status])
  @@index([sourceLanguage])
  @@index([targetLanguage])
}

model NewsArticle {
  id        String   @id @default(gen_random_ulid()) @map("id")
  orgId     String   @map("org_id")
  url       String   @map("url")
  title     String   @map("title")
  source    String   @map("source")
  sentiment String?  @map("sentiment")
  summary   String?  @map("summary")
  category  String   @default("general") @map("category")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([url])
  @@map("news_articles")
  @@index([orgId])
  @@index([source])
  @@index([sentiment])
  @@index([category])
  @@index([updatedAt(sort: Desc)])
}

// ============================================================================
// System & Administration Tables (public schema)
// ============================================================================

model WorkflowExecution {
  id              String    @id @default(gen_random_ulid()) @map("id")
  orgId           String    @map("org_id")
  workflowId      String    @map("workflow_id")
  stepId          String    @map("step_id")
  status          String    @default("pending") @map("status")
  inputData       Json?     @map("input_data")
  outputData      Json?     @map("output_data")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  category        String    @default("general") @map("category")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  actorId         String    @map("actor_id")
  idempotencyKey  String    @map("idempotency_key")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor User         @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([actorId, idempotencyKey])
  @@map("workflow_executions")
  @@index([orgId])
  @@index([workflowId])
  @@index([stepId])
  @@index([status])
  @@index([startedAt(sort: Desc)])
  @@index([actorId])
}

model AuditLog {
  id         String   @id @default(gen_random_ulid()) @map("id")
  orgId      String   @map("org_id")
  actorId    String?  @map("actor_id")
  action     String   @map("action")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  category   String   @default("general") @map("category")
  createdAt  DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
  @@index([orgId])
  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt(sort: Desc)])
}

model NotificationPreference {
  id        String   @id @default(gen_random_ulid()) @map("id")
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  channels  Json     @default("{}") @map("channels")
  category  String   @default("general") @map("category")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("notification_preferences")
  @@index([orgId])
  @@index([userId])
}

// ============================================================================
// Multi-Tenant Foundation Tables (public schema)
// ============================================================================

model OrganizationMember {
  orgId      String   @map("org_id")
  userId     String   @map("user_id")
  roleId     String?  @map("role_id")
  joinedDate DateTime @default(now()) @map("joined_date")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role  UserRole?    @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@id([orgId, userId])
  @@map("organization_members")
  @@index([orgId])
  @@index([userId])
  @@index([roleId])
}

model ConnectedAccount {
  id           String    @id @default(gen_random_ulid()) @map("id")
  orgId        String    @map("org_id")
  provider     String    @map("provider")
  grantId      String?   @map("grant_id")
  accessToken  String?   @map("access_token")
  expiresAt    DateTime? @map("expires_at")
  grantStatus  String    @default("active") @map("grant_status")
  category     String    @default("general") @map("category")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  emails Email[]

  @@map("connected_accounts")
  @@index([orgId])
  @@index([provider])
  @@index([grantStatus])
  @@index([expiresAt])
}

model Organization {
  id              String   @id @default(gen_random_ulid()) @map("id")
  slug            String   @unique @map("slug")
  name            String   @map("name")
  plan            String   @default("free") @map("plan")
  createdAt       DateTime @default(now()) @map("created_at")
  allowTraining   Boolean  @default(false) @map("allow_training_flag")
  updatedAt       DateTime @updatedAt @map("updated_at")

  albums               Album[]
  messages             Message[]
  threads              Thread[]
  projects             Project[]
  events               Event[]
  emails               Email[]
  contacts             Contact[]
  documents            Document[]
  media                Media[]
  transactions         Transaction[]
  goals                Goal[]
  researchNotebooks    ResearchNotebook[]
  flashcards           Flashcard[]
  conferenceRooms      ConferenceRoom[]
  translationSessions  TranslationSession[]
  newsArticles         NewsArticle[]
  workflowExecutions   WorkflowExecution[]
  auditLogs            AuditLog[]
  notificationPreferences NotificationPreference[]
  organizationMembers  OrganizationMember[]
  connectedAccounts    ConnectedAccount[]
  featureFlags         FeatureFlag[]
  notifications        Notification[]
  userRoles            UserRole[]
  agentDefinitions     AgentDefinition[]
  recurrenceRules      RecurrenceRule[]
  aiCostLogs           AiCostLog[]
  promptVersions       PromptVersion[]
  evaluationDatasets   EvaluationDataset[]
  evaluationRuns       EvaluationRun[]
  graphEntities        GraphEntity[]
  graphRelationships   GraphRelationship[]
  ragIndexStatistics   RagIndexStatistic[]
  mcpToolAuthorizations McpToolAuthorization[]
  passkeys             Passkey[]
  guardrailsAuditLogs  GuardrailsAuditLog[]
  ssrfAllowlists       SsrfAllowlist[]
  privacyTrainingOptouts PrivacyTrainingOptout[]
  stripeUsageRecords   StripeUsageRecord[]
  yjsDocumentLifecycles YjsDocumentLifecycle[]
  nylasWebhookConfigurations NylasWebhookConfiguration[]
  opentelemetrySpanDefinitions OpentelemetrySpanDefinition[]
  offlineTombstoneConfigurations OfflineTombstoneConfiguration[]
  realtimeLimitsConfigurations RealtimeLimitsConfiguration[]
  uploadSecurityConfigurations UploadSecurityConfiguration[]
  recurrenceRuleConfigurations RecurrenceRuleConfiguration[]
  collabDocuments      CollabDocument[]
  realtimeChannelMonitoring RealtimeChannelMonitoring[]
  offlineOperationsQueues OfflineOperationsQueue[]
  specificationMetadata SpecificationMetadata[]
  incidentManagement   IncidentManagement[]
  featureFlagRegistries FeatureFlagRegistry[]
  costBudgets          CostBudget[]
  sloDefinitions       SloDefinition[]
  securityControlMappings SecurityControlMapping[]
  webauthnChallenges   WebauthnChallenge[]
  secretRotationLogs   SecretRotationLog[]
  posthogEventTaxonomies PosthogEventTaxonomy[]
  featureFlagEvidences FeatureFlagEvidence[]
  testCoverageTargets  TestCoverageTarget[]
  workflowStateAudits  WorkflowStateAudit[]
  webhookDeduplications WebhookDeduplication[]
  realtimeLimitsConfiguration RealtimeLimitsConfiguration[]
  offlineTombstoneConfiguration OfflineTombstoneConfiguration[]
  uploadSecurityConfiguration UploadSecurityConfiguration[]
  recurrenceRuleConfiguration RecurrenceRuleConfiguration[]

  @@map("organizations")
  @@index([slug])
  @@index([plan])
  @@index([createdAt(sort: Desc)])
}

model FeatureFlag {
  id          String   @id @default(gen_random_ulid()) @map("id")
  orgId       String   @map("org_id")
  flagName    String   @map("flag_name")
  percentage  Decimal  @default(0.0) @map("percentage") @db.Decimal(5, 2)
  enabled     Boolean  @default(false) @map("enabled")
  category    String   @default("general") @map("category")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  org     Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  evidences FeatureFlagEvidence[]

  @@unique([orgId, flagName])
  @@map("feature_flags")
  @@index([orgId])
  @@index([flagName])
  @@index([enabled])
}

model Notification {
  id           String   @id @default(gen_random_ulid()) @map("id")
  orgId        String   @map("org_id")
  userId       String   @map("user_id")
  template     String   @map("template")
  deeplink     String?  @map("deeplink")
  readStatus   Boolean  @default(false) @map("read_status")
  unsubscribed Boolean  @default(false) @map("unsubscribed")
  category     String   @default("general") @map("category")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([orgId])
  @@index([userId])
  @@index([readStatus])
  @@index([unsubscribed])
  @@index([updatedAt(sort: Desc)])
}

// ============================================================================
// Role-Based Access Control Tables (public schema)
// ============================================================================

model UserRole {
  id          String   @id @default(gen_random_ulid()) @map("id")
  orgId       String   @map("org_id")
  name        String   @map("name")
  permissions Json     @default("{}") @map("permissions")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

